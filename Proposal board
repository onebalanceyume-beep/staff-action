<script>
"use strict";
var STORE_KEY = "onebalance_proposal_app_v1";
var state = { businesses: [] };
var editingBizId = null;
var editingItem = { bizId:null, itemId:null };
var tmpLogo = null;      // base64 or null
var tmpItemImg = null;   // base64 or null

/* ---------- storage ---------- */
function load(){
  try{
    var raw = localStorage.getItem(STORE_KEY);
    if(raw){ state = JSON.parse(raw); }
    else { state = defaultState(); save(); }
  }catch(e){ state = defaultState(); }
  if(!state.businesses) state.businesses = [];
}
function save(){
  try{ localStorage.setItem(STORE_KEY, JSON.stringify(state)); }
  catch(e){ toast("保存容量がいっぱいです。画像を減らしてください"); }
}
function defaultState(){
  return { businesses:[
    { id:uid(), name:"ワンバランスボクシングジム", logo:null, items:[] },
    { id:uid(), name:"ONE-TRE", logo:null, items:[] }
  ]};
}
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,7); }

/* ---------- render ---------- */
function render(){
  var wrap = document.getElementById("wrap");
  if(state.businesses.length===0){
    wrap.innerHTML = '<div class="empty" style="padding:50px 20px">右上の「＋ 事業を追加」から始めましょう</div>';
    return;
  }
  var html = "";
  state.businesses.forEach(function(b){
    var logo = b.logo
      ? '<img class="logo" src="'+b.logo+'" alt="">'
      : '<div class="logo"><div class="ph">'+initials(b.name)+'</div></div>';
    var items = "";
    if(b.items.length===0){
      items = '<div class="empty">提案がまだありません。下のボタンから追加</div>';
    } else {
      b.items.forEach(function(it){
        items += itemHtml(b.id, it);
      });
    }
    html +=
      '<div class="biz">'+
        '<div class="biz-head">'+
          logo+
          '<div class="biz-meta">'+
            '<div class="eyebrow">提案 '+b.items.length+'件</div>'+
            '<div class="biz-name">'+esc(b.name)+'</div>'+
          '</div>'+
          '<div class="head-actions">'+
            '<button class="icobtn" title="編集" onclick="openBizModal(\''+b.id+'\')">'+ICON.edit+'</button>'+
            '<button class="icobtn" title="削除" onclick="askDeleteBiz(\''+b.id+'\')">'+ICON.trash+'</button>'+
          '</div>'+
        '</div>'+
        '<div class="items">'+items+
          '<button class="add-item" onclick="openItemModal(\''+b.id+'\',null)">＋ 提案を追加</button>'+
        '</div>'+
      '</div>';
  });
  wrap.innerHTML = html;
}

function itemHtml(bizId, it){
  var tags = "";
  if(it.url) tags += '<span class="tag url">URL</span>';
  if(it.img) tags += '<span class="tag img">画像</span>';
  var body = "";
  if(it.memo) body += '<div class="memo">'+esc(it.memo)+'</div>';
  if(it.url){
    body +=
      '<div class="attach-row">'+
        '<button class="btn copy" onclick="copyUrl(\''+jsq(it.url)+'\')">'+ICON.copy+'コピー</button>'+
        '<button class="btn qr" onclick="showQR(\''+jsq(it.url)+'\')">'+ICON.qr+'QRコード</button>'+
      '</div>'+
      '<div class="urltext">'+esc(it.url)+'</div>';
  }
  if(it.img){
    body += '<img class="item-img" src="'+it.img+'" alt="" onclick="viewImg(\''+jsq(it.img)+'\')">';
  }
  if(!it.memo && !it.url && !it.img){
    body += '<div class="memo" style="color:#8a94a0">（内容なし）</div>';
  }
  body +=
    '<div class="item-edit">'+
      '<button class="linkbtn" onclick="openItemModal(\''+bizId+'\',\''+it.id+'\')">編集</button>'+
      '<button class="linkbtn del" onclick="askDeleteItem(\''+bizId+'\',\''+it.id+'\')">削除</button>'+
    '</div>';
  return ''+
    '<div class="item" id="item-'+it.id+'">'+
      '<button class="item-head" onclick="toggleItem(\''+it.id+'\')">'+
        '<span class="dot"></span>'+
        '<span class="item-title">'+esc(it.title)+'</span>'+
        '<span class="item-tags">'+tags+'</span>'+
        ICON.chev+
      '</button>'+
      '<div class="item-body">'+body+'</div>'+
    '</div>';
}

function toggleItem(id){
  var el = document.getElementById("item-"+id);
  if(el) el.classList.toggle("open");
}

/* ---------- business modal ---------- */
function openBizModal(id){
  editingBizId = id;
  var nameI = document.getElementById("bizName");
  if(id){
    var b = findBiz(id);
    document.getElementById("bizModalTitle").textContent = "事業を編集";
    nameI.value = b.name;
    tmpLogo = b.logo || null;
  } else {
    document.getElementById("bizModalTitle").textContent = "事業を追加";
    nameI.value = "";
    tmpLogo = null;
  }
  refreshLogoPrev();
  openOverlay("bizOverlay");
  setTimeout(function(){ nameI.focus(); },250);
}
function refreshLogoPrev(){
  var prev = document.getElementById("bizLogoPrev");
  var clr = document.getElementById("bizLogoClear");
  if(tmpLogo){
    prev.outerHTML = '<img id="bizLogoPrev" class="prev" src="'+tmpLogo+'" alt="">';
    clr.style.display = "inline-block";
  } else {
    prev.outerHTML = '<div id="bizLogoPrev" class="prev ph">1B</div>';
    clr.style.display = "none";
  }
}
function onLogoPick(e){
  var f = e.target.files[0]; if(!f) return;
  resizeImage(f, 256, 0.85, function(data){ tmpLogo = data; refreshLogoPrev(); });
  e.target.value = "";
}
function clearLogo(){ tmpLogo = null; refreshLogoPrev(); }
function saveBiz(){
  var name = document.getElementById("bizName").value.trim();
  if(!name){ toast("事業名を入れてください"); return; }
  if(editingBizId){
    var b = findBiz(editingBizId);
    b.name = name; b.logo = tmpLogo;
  } else {
    state.businesses.push({ id:uid(), name:name, logo:tmpLogo, items:[] });
  }
  save(); render(); closeOverlay("bizOverlay");
}
function askDeleteBiz(id){
  var b = findBiz(id);
  showConfirm("この事業を削除しますか？", "「"+b.name+"」と中の提案"+b.items.length+"件がすべて消えます。\nこの操作は取り消せません。", function(){
    state.businesses = state.businesses.filter(function(x){ return x.id!==id; });
    save(); render(); closeOverlay("confirmOverlay");
    toast("削除しました");
  });
}

/* ---------- item modal ---------- */
function openItemModal(bizId, itemId){
  editingItem = { bizId:bizId, itemId:itemId };
  var t = document.getElementById("itemTitle");
  if(itemId){
    var it = findItem(bizId, itemId);
    document.getElementById("itemModalTitle").textContent = "提案を編集";
    t.value = it.title;
    document.getElementById("itemMemo").value = it.memo||"";
    document.getElementById("itemUrl").value = it.url||"";
    tmpItemImg = it.img||null;
  } else {
    document.getElementById("itemModalTitle").textContent = "提案を追加";
    t.value=""; document.getElementById("itemMemo").value="";
    document.getElementById("itemUrl").value=""; tmpItemImg=null;
  }
  refreshItemImgPrev();
  openOverlay("itemOverlay");
  setTimeout(function(){ t.focus(); },250);
}
function refreshItemImgPrev(){
  var prev = document.getElementById("itemImgPrev");
  var clr = document.getElementById("itemImgClear");
  if(tmpItemImg){
    prev.outerHTML = '<img id="itemImgPrev" class="prev" src="'+tmpItemImg+'" alt="">';
    clr.style.display="inline-block";
  } else {
    prev.outerHTML = '<div id="itemImgPrev" class="prev ph">画像</div>';
    clr.style.display="none";
  }
}
function onItemImgPick(e){
  var f = e.target.files[0]; if(!f) return;
  resizeImage(f, 1000, 0.82, function(data){ tmpItemImg = data; refreshItemImgPrev(); });
  e.target.value="";
}
function clearItemImg(){ tmpItemImg=null; refreshItemImgPrev(); }
function saveItem(){
  var title = document.getElementById("itemTitle").value.trim();
  if(!title){ toast("タイトルを入れてください"); return; }
  var memo = document.getElementById("itemMemo").value.trim();
  var url = document.getElementById("itemUrl").value.trim();
  var b = findBiz(editingItem.bizId);
  if(editingItem.itemId){
    var it = findItem(editingItem.bizId, editingItem.itemId);
    it.title=title; it.memo=memo; it.url=url; it.img=tmpItemImg;
  } else {
    b.items.push({ id:uid(), title:title, memo:memo, url:url, img:tmpItemImg });
  }
  save(); render(); closeOverlay("itemOverlay");
}
function askDeleteItem(bizId, itemId){
  var it = findItem(bizId, itemId);
  showConfirm("この提案を削除しますか？", "「"+it.title+"」を削除します。\nこの操作は取り消せません。", function(){
    var b = findBiz(bizId);
    b.items = b.items.filter(function(x){ return x.id!==itemId; });
    save(); render(); closeOverlay("confirmOverlay");
    toast("削除しました");
  });
}

/* ---------- url / qr ---------- */
function copyUrl(url){
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(url).then(function(){ toast("URLをコピーしました"); },
      function(){ legacyCopy(url); });
  } else { legacyCopy(url); }
}
function legacyCopy(url){
  var ta=document.createElement("textarea"); ta.value=url;
  ta.style.position="fixed"; ta.style.opacity="0"; document.body.appendChild(ta);
  ta.focus(); ta.select();
  try{ document.execCommand("copy"); toast("URLをコピーしました"); }
  catch(e){ toast("コピーできませんでした"); }
  document.body.removeChild(ta);
}
function showQR(url){
  var box = document.getElementById("qrCanvas");
  box.innerHTML="";
  try{
    var qr = qrcode(0,"M");
    qr.addData(url); qr.make();
    box.innerHTML = qr.createImgTag(6,8);
    var img = box.querySelector("img");
    if(img){ img.style.width="220px"; img.style.height="220px"; img.style.imageRendering="pixelated"; }
  }catch(e){ box.innerHTML='<div style="padding:30px;color:#8a94a0">QRを作れませんでした</div>'; }
  document.getElementById("qrUrl").textContent = url;
  openOverlay("qrOverlay");
}

/* ---------- confirm ---------- */
function showConfirm(title, msg, onYes){
  document.getElementById("confirmTitle").textContent = title;
  document.getElementById("confirmMsg").textContent = msg;
  var yes = document.getElementById("confirmYes");
  var clone = yes.cloneNode(true);
  yes.parentNode.replaceChild(clone, yes);
  clone.id="confirmYes";
  clone.addEventListener("click", onYes);
  openOverlay("confirmOverlay");
}

/* ---------- image viewer ---------- */
function viewImg(src){
  document.getElementById("imgViewerImg").src = src;
  document.getElementById("imgViewer").classList.add("show");
}

/* ---------- helpers ---------- */
function findBiz(id){ return state.businesses.find(function(b){ return b.id===id; }); }
function findItem(bizId,itemId){ var b=findBiz(bizId); return b?b.items.find(function(x){return x.id===itemId;}):null; }
function initials(name){
  if(!name) return "?";
  var n=name.replace(/\s/g,"");
  return n.slice(0,2);
}
function esc(s){ return (s||"").replace(/[&<>"]/g,function(c){return {"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c];}); }
function jsq(s){ return (s||"").replace(/\\/g,"\\\\").replace(/'/g,"\\'").replace(/\n/g,"\\n").replace(/\r/g,""); }

function resizeImage(file, maxSide, quality, cb){
  var reader=new FileReader();
  reader.onload=function(ev){
    var img=new Image();
    img.onload=function(){
      var w=img.width,h=img.height;
      if(w>h && w>maxSide){ h=Math.round(h*maxSide/w); w=maxSide; }
      else if(h>=w && h>maxSide){ w=Math.round(w*maxSide/h); h=maxSide; }
      var c=document.createElement("canvas"); c.width=w; c.height=h;
      c.getContext("2d").drawImage(img,0,0,w,h);
      try{ cb(c.toDataURL("image/jpeg",quality)); }
      catch(e){ cb(ev.target.result); }
    };
    img.onerror=function(){ cb(ev.target.result); };
    img.src=ev.target.result;
  };
  reader.readAsDataURL(file);
}

/* ---------- overlay / toast ---------- */
function openOverlay(id){ document.getElementById(id).classList.add("show"); }
function closeOverlay(id){ document.getElementById(id).classList.remove("show"); }
var toastTimer=null;
function toast(msg){
  var t=document.getElementById("toast");
  t.textContent=msg; t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer=setTimeout(function(){ t.classList.remove("show"); },1900);
}
[].forEach.call(document.querySelectorAll(".overlay"),function(ov){
  ov.addEventListener("click",function(e){ if(e.target===ov) ov.classList.remove("show"); });
});

/* ---------- cache update ---------- */
function forceUpdate(){
  if("serviceWorker" in navigator){
    navigator.serviceWorker.getRegistrations().then(function(rs){ rs.forEach(function(r){ r.unregister(); }); });
  }
  if(window.caches && caches.keys){
    caches.keys().then(function(keys){ keys.forEach(function(k){ caches.delete(k); }); }).finally(function(){ location.reload(true); });
  } else { location.reload(true); }
}

/* ---------- icons ---------- */
var ICON = {
  edit:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>',
  trash:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M6 6l1 14h10l1-14"/></svg>',
  chev:'<svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>',
  copy:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>',
  qr:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M21 14v0M17 21h4M21 17v4"/></svg>'
};

/* ---------- manifest (home screen) ---------- */
(function(){
  var icon = "data:image/png;base64,";
  var manifest = {
    name:"ワンバランス 提案ボード", short_name:"提案ボード",
    display:"standalone", background_color:"#ffffff", theme_color:"#ffffff",
    start_url:".", icons:[
      {src:icon, sizes:"512x512", type:"image/png", purpose:"any maskable"}
    ]
  };
  var blob = new Blob([JSON.stringify(manifest)],{type:"application/json"});
  var l=document.createElement("link"); l.rel="manifest"; l.href=URL.createObjectURL(blob);
  document.head.appendChild(l);
})();

/* ---------- init ---------- */
load();
render();
</script>
</body>
</html>
