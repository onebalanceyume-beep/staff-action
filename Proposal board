<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta http-equiv="Pragma" content="no-cache">
<meta http-equiv="Expires" content="0">
<meta name="theme-color" content="#ffffff">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="提案ボード">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<link rel="icon" href="data:image/png;base64,">
<title>ワンバランス 提案ボード</title>
<style>
:root{
  --crimson:#AD002D; --crimson-deep:#7E0020; --crimson-soft:#F6E4E8;
  --ink:#15110f; --ink2:#3d3835; --muted:#928c87; --line:#ecebe9;
  --paper:#ffffff; --surface:#faf9f8;
  --radius:18px; --shadow:0 1px 2px rgba(30,20,15,.05),0 10px 30px rgba(30,20,15,.05);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{-webkit-text-size-adjust:100%;text-size-adjust:100%}
body{
  margin:0;background:var(--paper);color:var(--ink);
  font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Hiragino Kaku Gothic ProN","Noto Sans JP","Yu Gothic UI",sans-serif;
  line-height:1.55;-webkit-font-smoothing:antialiased;
  padding-bottom:env(safe-area-inset-bottom);
}
button,input,textarea{font-family:inherit;font-size:16px;color:inherit}
button{cursor:pointer;border:none;background:none;touch-action:manipulation}

/* ---- top bar (white) ---- */
.topbar{
  position:sticky;top:0;z-index:30;background:rgba(255,255,255,.92);
  backdrop-filter:saturate(180%) blur(12px);-webkit-backdrop-filter:saturate(180%) blur(12px);
  border-bottom:1px solid var(--line);
  padding:calc(env(safe-area-inset-top) + 14px) 20px 14px;
}
.topbar .row{display:flex;align-items:center;justify-content:space-between;gap:12px;max-width:780px;margin:0 auto}
.topbar h1{margin:0;font-size:21px;font-weight:800;letter-spacing:-.02em;display:flex;align-items:center;gap:11px;line-height:1}
.topbar h1 .mark{width:30px;height:30px;border-radius:9px;background:var(--crimson);color:#fff;display:grid;place-items:center;font-size:13px;font-weight:800;letter-spacing:0}
.topbar .sub{font-size:11px;color:var(--muted);margin-top:6px;font-weight:700;letter-spacing:.02em}
.add-biz{background:var(--crimson);color:#fff;font-weight:800;font-size:13px;letter-spacing:.01em;padding:11px 16px;border-radius:999px;white-space:nowrap;transition:transform .1s,background .15s}
.add-biz:active{transform:scale(.95);background:var(--crimson-deep)}

/* ---- layout ---- */
.wrap{max-width:780px;margin:0 auto;padding:22px 16px 90px}

/* ---- business card ---- */
.biz{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:20px;overflow:hidden}
.biz-head{display:flex;align-items:center;gap:14px;padding:18px 18px 16px}
.logo{width:58px;height:58px;border-radius:15px;flex:none;object-fit:cover;background:var(--surface);overflow:hidden;border:1px solid var(--line)}
.logo .ph{width:100%;height:100%;display:grid;place-items:center;color:#fff;font-weight:800;font-size:21px;letter-spacing:.02em;background:var(--crimson)}
.biz-meta{flex:1;min-width:0}
.eyebrow{font-size:10px;font-weight:800;letter-spacing:.18em;color:var(--crimson);text-transform:uppercase;margin-bottom:5px}
.biz-name{font-size:23px;font-weight:800;line-height:1.18;letter-spacing:-.015em;word-break:break-word;color:var(--ink)}
.biz-count{font-size:12px;color:var(--muted);font-weight:700;margin-top:7px;letter-spacing:.02em}
.icobtn{width:36px;height:36px;border-radius:10px;display:grid;place-items:center;color:var(--muted);flex:none;transition:background .15s,color .15s}
.icobtn:active{background:var(--surface);color:var(--ink)}
.icobtn svg{width:18px;height:18px}
.head-actions{display:flex;gap:2px;flex:none;align-self:flex-start}

/* ---- items ---- */
.items{padding:0 12px 14px}
.empty{padding:20px 12px;color:var(--muted);font-size:13px;text-align:center;letter-spacing:.01em}
.item{border-radius:13px;margin:8px 0;background:var(--surface);border:1px solid var(--line);overflow:hidden;transition:border-color .18s}
.item.open{border-color:var(--crimson);background:#fff}
.item-head{display:flex;align-items:center;gap:11px;padding:15px 14px;width:100%;text-align:left}
.item-head .dot{width:7px;height:7px;border-radius:2px;background:var(--crimson);flex:none}
.item-title{flex:1;font-weight:700;font-size:15.5px;letter-spacing:-.005em;min-width:0;word-break:break-word;color:var(--ink)}
.item-tags{display:flex;gap:5px;flex:none}
.tag{font-size:10px;font-weight:800;padding:4px 8px;border-radius:6px;letter-spacing:.06em}
.tag.url{background:var(--crimson-soft);color:var(--crimson)}
.tag.img{background:#efedec;color:#6e6862}
.chev{width:18px;height:18px;color:var(--muted);flex:none;transition:transform .22s}
.item.open .chev{transform:rotate(180deg);color:var(--crimson)}
.item-body{display:none;padding:2px 16px 18px 32px}
.item.open .item-body{display:block}
.memo{font-size:14.5px;color:var(--ink2);white-space:pre-wrap;word-break:break-word;margin:4px 0 14px;line-height:1.65}
.attach-row{display:flex;flex-wrap:wrap;gap:9px;align-items:center}
.btn{display:inline-flex;align-items:center;gap:7px;font-weight:800;font-size:13px;letter-spacing:.01em;padding:11px 16px;border-radius:11px;transition:transform .1s,background .15s}
.btn svg{width:15px;height:15px}
.btn.copy{background:var(--crimson);color:#fff}
.btn.copy:active{background:var(--crimson-deep)}
.btn.qr{background:#fff;color:var(--crimson);border:1.5px solid var(--crimson)}
.btn.qr:active{background:var(--crimson-soft)}
.btn:active{transform:scale(.97)}
.urltext{font-size:11.5px;color:var(--muted);word-break:break-all;margin-top:10px;letter-spacing:.01em}
.item-img{margin-top:12px;max-width:170px;border-radius:11px;border:1px solid var(--line);display:block}
.item-edit{margin-top:14px;display:flex;gap:18px}
.linkbtn{font-size:12.5px;font-weight:800;color:var(--muted);letter-spacing:.03em}
.linkbtn.del{color:var(--crimson)}
.add-item{width:100%;margin:8px 0 2px;padding:14px;border-radius:12px;border:1.5px dashed #d8d4d0;color:var(--crimson);font-weight:800;font-size:13px;letter-spacing:.02em;background:#fff;transition:background .15s}
.add-item:active{background:var(--surface)}

/* ---- modal ---- */
.overlay{position:fixed;inset:0;background:rgba(21,17,15,.42);display:none;align-items:flex-end;justify-content:center;z-index:50}
.overlay.show{display:flex}
.sheet{background:#fff;width:100%;max-width:520px;border-radius:24px 24px 0 0;padding:24px 20px calc(22px + env(safe-area-inset-bottom));max-height:92vh;overflow:auto;animation:up .24s cubic-bezier(.22,1,.36,1)}
@media(min-width:560px){.overlay{align-items:center;padding:20px}.sheet{border-radius:22px;animation:pop .2s ease}}
@keyframes up{from{transform:translateY(50px);opacity:.5}to{transform:none;opacity:1}}
@keyframes pop{from{transform:scale(.96);opacity:.5}to{transform:none;opacity:1}}
.sheet h2{margin:0 0 20px;font-size:20px;font-weight:800;letter-spacing:-.02em}
.field{margin-bottom:17px}
.field label{display:block;font-size:11px;font-weight:800;margin-bottom:8px;color:var(--ink);letter-spacing:.08em;text-transform:uppercase}
.field .hint{font-weight:700;color:var(--muted);font-size:11px;letter-spacing:0;text-transform:none}
.field input[type=text],.field textarea{width:100%;border:1.5px solid var(--line);border-radius:12px;padding:13px;background:var(--surface);color:var(--ink)}
.field input:focus,.field textarea:focus{outline:none;border-color:var(--crimson);background:#fff}
.field textarea{min-height:96px;resize:vertical;line-height:1.6}
.uploader{display:flex;align-items:center;gap:13px}
.uploader .prev{width:62px;height:62px;border-radius:15px;object-fit:cover;background:var(--surface);flex:none;border:1px solid var(--line)}
.uploader .prev.ph{display:grid;place-items:center;color:#fff;font-weight:800;font-size:13px;letter-spacing:.02em;background:var(--crimson);border:none}
.filebtn{font-size:12.5px;font-weight:800;color:var(--crimson);padding:10px 15px;border:1.5px solid var(--crimson);border-radius:11px;letter-spacing:.02em}
.filebtn.clear{color:var(--muted);border-color:var(--line)}
.sheet-actions{display:flex;gap:11px;margin-top:10px}
.sheet-actions .save{flex:1;background:var(--crimson);color:#fff;font-weight:800;padding:15px;border-radius:13px;font-size:15px;letter-spacing:.02em}
.sheet-actions .save:active{background:var(--crimson-deep)}
.sheet-actions .cancel{flex:none;background:var(--surface);color:var(--ink2);font-weight:800;padding:15px 22px;border-radius:13px;border:1px solid var(--line)}

/* confirm */
.confirm-box{text-align:center}
.confirm-box .ttl{font-size:18px;font-weight:800;margin-bottom:10px;letter-spacing:-.01em}
.confirm-box .msg{font-size:13.5px;color:var(--ink2);margin-bottom:22px;white-space:pre-wrap;line-height:1.7}
.confirm-actions{display:flex;gap:11px}
.confirm-actions button{flex:1;padding:15px;border-radius:13px;font-weight:800;font-size:15px}
.confirm-actions .yes{background:var(--crimson);color:#fff}
.confirm-actions .no{background:var(--surface);color:var(--ink2);border:1px solid var(--line)}

/* qr modal */
.qr-box{text-align:center}
.qr-box h2{margin-bottom:18px}
.qr-canvas{display:inline-block;padding:18px;background:#fff;border-radius:18px;border:1px solid var(--line)}
.qr-canvas img,.qr-canvas table{width:220px;height:220px}
.qr-url{font-size:11.5px;color:var(--muted);word-break:break-all;margin:16px 0 4px}
.qr-close{margin-top:18px;width:100%;background:var(--surface);color:var(--ink2);font-weight:800;padding:15px;border-radius:13px;border:1px solid var(--line)}

/* toast */
.toast{position:fixed;left:50%;bottom:calc(30px + env(safe-area-inset-bottom));transform:translateX(-50%) translateY(20px);background:var(--ink);color:#fff;font-weight:700;font-size:13.5px;letter-spacing:.02em;padding:12px 22px;border-radius:999px;opacity:0;pointer-events:none;transition:.26s cubic-bezier(.22,1,.36,1);z-index:80}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* footer */
.foot{max-width:780px;margin:0 auto;padding:0 18px 34px;display:flex;align-items:center;justify-content:space-between;color:var(--muted);font-size:11px;letter-spacing:.03em}
.foot button{color:var(--crimson);font-weight:800;font-size:11px;letter-spacing:.03em}

.img-viewer{position:fixed;inset:0;background:rgba(0,0,0,.88);display:none;align-items:center;justify-content:center;z-index:90;padding:20px}
.img-viewer.show{display:flex}
.img-viewer img{max-width:100%;max-height:100%;border-radius:10px}
</style>
</head>
<body>

<div class="topbar">
  <div class="row">
    <div>
      <h1><span class="mark">1B</span> 提案ボード</h1>
      <div class="sub">お客様に「今これ出せる」を一目で</div>
    </div>
    <button class="add-biz" onclick="openBizModal(null)">＋ 事業を追加</button>
  </div>
</div>

<div class="wrap" id="wrap"></div>

<div class="foot">
  <span>ワンバランス 提案ボード v1.1</span>
  <button onclick="forceUpdate()">最新版に更新</button>
</div>

<!-- business modal -->
<div class="overlay" id="bizOverlay">
  <div class="sheet">
    <h2 id="bizModalTitle">事業を追加</h2>
    <div class="field">
      <label>事業名</label>
      <input type="text" id="bizName" placeholder="例：ワンバランスボクシングジム">
    </div>
    <div class="field">
      <label>ロゴ <span class="hint">（四角い画像が◎ / 未設定でもOK）</span></label>
      <div class="uploader">
        <div id="bizLogoPrev" class="prev ph">1B</div>
        <input type="file" id="bizLogoFile" accept="image/*" style="display:none" onchange="onLogoPick(event)">
        <button class="filebtn" onclick="document.getElementById('bizLogoFile').click()">画像を選ぶ</button>
        <button class="filebtn clear" id="bizLogoClear" onclick="clearLogo()" style="display:none">削除</button>
      </div>
    </div>
    <div class="sheet-actions">
      <button class="cancel" onclick="closeOverlay('bizOverlay')">キャンセル</button>
      <button class="save" onclick="saveBiz()">保存</button>
    </div>
  </div>
</div>

<!-- item modal -->
<div class="overlay" id="itemOverlay">
  <div class="sheet">
    <h2 id="itemModalTitle">提案を追加</h2>
    <div class="field">
      <label>タイトル</label>
      <input type="text" id="itemTitle" placeholder="例：Google口コミのお願い">
    </div>
    <div class="field">
      <label>メモ・トーク内容 <span class="hint">（任意）</span></label>
      <textarea id="itemMemo" placeholder="スタッフが見て分かるように。声かけ例・条件・注意点など"></textarea>
    </div>
    <div class="field">
      <label>URL <span class="hint">（任意 / コピー・QRが出せます）</span></label>
      <input type="text" id="itemUrl" placeholder="https://...">
    </div>
    <div class="field">
      <label>画像 <span class="hint">（任意 / チラシ・見本など）</span></label>
      <div class="uploader">
        <div id="itemImgPrev" class="prev ph">画像</div>
        <input type="file" id="itemImgFile" accept="image/*" style="display:none" onchange="onItemImgPick(event)">
        <button class="filebtn" onclick="document.getElementById('itemImgFile').click()">画像を選ぶ</button>
        <button class="filebtn clear" id="itemImgClear" onclick="clearItemImg()" style="display:none">削除</button>
      </div>
    </div>
    <div class="sheet-actions">
      <button class="cancel" onclick="closeOverlay('itemOverlay')">キャンセル</button>
      <button class="save" onclick="saveItem()">保存</button>
    </div>
  </div>
</div>

<!-- confirm modal -->
<div class="overlay" id="confirmOverlay">
  <div class="sheet confirm-box">
    <div class="ttl" id="confirmTitle">削除しますか？</div>
    <div class="msg" id="confirmMsg"></div>
    <div class="confirm-actions">
      <button class="no" onclick="closeOverlay('confirmOverlay')">やめる</button>
      <button class="yes" id="confirmYes">削除する</button>
    </div>
  </div>
</div>

<!-- qr modal -->
<div class="overlay" id="qrOverlay">
  <div class="sheet qr-box">
    <h2>QRコード</h2>
    <div class="qr-canvas" id="qrCanvas"></div>
    <div class="qr-url" id="qrUrl"></div>
    <button class="qr-close" onclick="closeOverlay('qrOverlay')">閉じる</button>
  </div>
</div>

<div class="img-viewer" id="imgViewer" onclick="this.classList.remove('show')">
  <img id="imgViewerImg" src="" alt="">
</div>

<div class="toast" id="toast"></div>

<script>
//---------------------------------------------------------------------
//
// QR Code Generator for JavaScript
//
// Copyright (c) 2009 Kazuhiko Arase
//
// URL: http://www.d-project.com/
//
// Licensed under the MIT license:
//  http://www.opensource.org/licenses/mit-license.php
//
// The word 'QR Code' is registered trademark of
// DENSO WAVE INCORPORATED
//  http://www.denso-wave.com/qrcode/faqpatent-e.html
//
//---------------------------------------------------------------------

var qrcode = function() {

  //---------------------------------------------------------------------
  // qrcode
  //---------------------------------------------------------------------

  /**
   * qrcode
   * @param typeNumber 1 to 40
   * @param errorCorrectionLevel 'L','M','Q','H'
   */
  var qrcode = function(typeNumber, errorCorrectionLevel) {

    var PAD0 = 0xEC;
    var PAD1 = 0x11;

    var _typeNumber = typeNumber;
    var _errorCorrectionLevel = QRErrorCorrectionLevel[errorCorrectionLevel];
    var _modules = null;
    var _moduleCount = 0;
    var _dataCache = null;
    var _dataList = [];

    var _this = {};

    var makeImpl = function(test, maskPattern) {

      _moduleCount = _typeNumber * 4 + 17;
      _modules = function(moduleCount) {
        var modules = new Array(moduleCount);
        for (var row = 0; row < moduleCount; row += 1) {
          modules[row] = new Array(moduleCount);
          for (var col = 0; col < moduleCount; col += 1) {
            modules[row][col] = null;
          }
        }
        return modules;
      }(_moduleCount);

      setupPositionProbePattern(0, 0);
      setupPositionProbePattern(_moduleCount - 7, 0);
      setupPositionProbePattern(0, _moduleCount - 7);
      setupPositionAdjustPattern();
      setupTimingPattern();
      setupTypeInfo(test, maskPattern);

      if (_typeNumber >= 7) {
        setupTypeNumber(test);
      }

      if (_dataCache == null) {
        _dataCache = createData(_typeNumber, _errorCorrectionLevel, _dataList);
      }

      mapData(_dataCache, maskPattern);
    };

    var setupPositionProbePattern = function(row, col) {

      for (var r = -1; r <= 7; r += 1) {

        if (row + r <= -1 || _moduleCount <= row + r) continue;

        for (var c = -1; c <= 7; c += 1) {

          if (col + c <= -1 || _moduleCount <= col + c) continue;

          if ( (0 <= r && r <= 6 && (c == 0 || c == 6) )
              || (0 <= c && c <= 6 && (r == 0 || r == 6) )
              || (2 <= r && r <= 4 && 2 <= c && c <= 4) ) {
            _modules[row + r][col + c] = true;
          } else {
            _modules[row + r][col + c] = false;
          }
        }
      }
    };

    var getBestMaskPattern = function() {

      var minLostPoint = 0;
      var pattern = 0;

      for (var i = 0; i < 8; i += 1) {

        makeImpl(true, i);

        var lostPoint = QRUtil.getLostPoint(_this);

        if (i == 0 || minLostPoint > lostPoint) {
          minLostPoint = lostPoint;
          pattern = i;
        }
      }

      return pattern;
    };

    var setupTimingPattern = function() {

      for (var r = 8; r < _moduleCount - 8; r += 1) {
        if (_modules[r][6] != null) {
          continue;
        }
        _modules[r][6] = (r % 2 == 0);
      }

      for (var c = 8; c < _moduleCount - 8; c += 1) {
        if (_modules[6][c] != null) {
          continue;
        }
        _modules[6][c] = (c % 2 == 0);
      }
    };

    var setupPositionAdjustPattern = function() {

      var pos = QRUtil.getPatternPosition(_typeNumber);

      for (var i = 0; i < pos.length; i += 1) {

        for (var j = 0; j < pos.length; j += 1) {

          var row = pos[i];
          var col = pos[j];

          if (_modules[row][col] != null) {
            continue;
          }

          for (var r = -2; r <= 2; r += 1) {

            for (var c = -2; c <= 2; c += 1) {

              if (r == -2 || r == 2 || c == -2 || c == 2
                  || (r == 0 && c == 0) ) {
                _modules[row + r][col + c] = true;
              } else {
                _modules[row + r][col + c] = false;
              }
            }
          }
        }
      }
    };

    var setupTypeNumber = function(test) {

      var bits = QRUtil.getBCHTypeNumber(_typeNumber);

      for (var i = 0; i < 18; i += 1) {
        var mod = (!test && ( (bits >> i) & 1) == 1);
        _modules[Math.floor(i / 3)][i % 3 + _moduleCount - 8 - 3] = mod;
      }

      for (var i = 0; i < 18; i += 1) {
        var mod = (!test && ( (bits >> i) & 1) == 1);
        _modules[i % 3 + _moduleCount - 8 - 3][Math.floor(i / 3)] = mod;
      }
    };

    var setupTypeInfo = function(test, maskPattern) {

      var data = (_errorCorrectionLevel << 3) | maskPattern;
      var bits = QRUtil.getBCHTypeInfo(data);

      // vertical
      for (var i = 0; i < 15; i += 1) {

        var mod = (!test && ( (bits >> i) & 1) == 1);

        if (i < 6) {
          _modules[i][8] = mod;
        } else if (i < 8) {
          _modules[i + 1][8] = mod;
        } else {
          _modules[_moduleCount - 15 + i][8] = mod;
        }
      }

      // horizontal
      for (var i = 0; i < 15; i += 1) {

        var mod = (!test && ( (bits >> i) & 1) == 1);

        if (i < 8) {
          _modules[8][_moduleCount - i - 1] = mod;
        } else if (i < 9) {
          _modules[8][15 - i - 1 + 1] = mod;
        } else {
          _modules[8][15 - i - 1] = mod;
        }
      }

      // fixed module
      _modules[_moduleCount - 8][8] = (!test);
    };

    var mapData = function(data, maskPattern) {

      var inc = -1;
      var row = _moduleCount - 1;
      var bitIndex = 7;
      var byteIndex = 0;
      var maskFunc = QRUtil.getMaskFunction(maskPattern);

      for (var col = _moduleCount - 1; col > 0; col -= 2) {

        if (col == 6) col -= 1;

        while (true) {

          for (var c = 0; c < 2; c += 1) {

            if (_modules[row][col - c] == null) {

              var dark = false;

              if (byteIndex < data.length) {
                dark = ( ( (data[byteIndex] >>> bitIndex) & 1) == 1);
              }

              var mask = maskFunc(row, col - c);

              if (mask) {
                dark = !dark;
              }

              _modules[row][col - c] = dark;
              bitIndex -= 1;

              if (bitIndex == -1) {
                byteIndex += 1;
                bitIndex = 7;
              }
            }
          }

          row += inc;

          if (row < 0 || _moduleCount <= row) {
            row -= inc;
            inc = -inc;
            break;
          }
        }
      }
    };

    var createBytes = function(buffer, rsBlocks) {

      var offset = 0;

      var maxDcCount = 0;
      var maxEcCount = 0;

      var dcdata = new Array(rsBlocks.length);
      var ecdata = new Array(rsBlocks.length);

      for (var r = 0; r < rsBlocks.length; r += 1) {

        var dcCount = rsBlocks[r].dataCount;
        var ecCount = rsBlocks[r].totalCount - dcCount;

        maxDcCount = Math.max(maxDcCount, dcCount);
        maxEcCount = Math.max(maxEcCount, ecCount);

